# --- Payload ---
PAYLOAD_SECRET=replace-with-a-long-random-string

# --- Database (Neon Postgres free tier) ---
# Sign up at neon.tech, create a project, paste the pooled connection string here
DATABASE_URI=postgres://user:password@host/dbname?sslmode=require

# --- Storage (Vercel Blob free tier on Vercel Hobby) ---
# In your Vercel project → Storage → Create Blob Store. Token is generated automatically.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxx

# --- Public URLs ---
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# --- Optional: Resend for the contact form ---
# RESEND_API_KEY=re_xxxxxxxxxx
# CONTACT_EMAIL_TO=josh@schaeffer.design
